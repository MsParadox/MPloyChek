

# ── Database (Neon — neon.tech) ───────────────────
# Get both strings from Neon dashboard → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/mploychek?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/mploychek?sslmode=require

# ── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-32-char-random-secret
JWT_EXPIRES_IN=28800
# How many days a refresh token stays valid
RT_EXPIRES_DAYS=7

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:4200
FRONTEND_URL=http://localhost:4200

# ── Cloudinary (file uploads — cloudinary.com) ────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# ── Brevo (email — brevo.com , 300/day) ────────────
BREVO_SMTP_LOGIN=your-brevo-login@email.com
BREVO_SMTP_PASSWORD=your-smtp-password
BREVO_SENDER_EMAIL=noreply@mploychek.com

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
