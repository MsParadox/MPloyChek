
# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
LOG_TO_FILE=true

# ── Database: Neon PostgreSQL  ─────────────────
# 1. Sign up → https://neon.tech (no credit card)
# 2. Create project → copy both strings from dashboard
DATABASE_URL="postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── JWT Authentication ───────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=replace_with_at_least_32_random_characters_here_xxxx
JWT_EXPIRES_IN=28800       # access token TTL: 8 hours
RT_EXPIRES_DAYS=7          # refresh token TTL: 7 days

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:4200
FRONTEND_URL=https://your-vercel-app.vercel.app

# ── Email: Brevo  ─────
# 1. Sign up → https://brevo.com
# 2. Settings → SMTP & API → SMTP tab → Generate credentials
BREVO_SMTP_LOGIN=your_brevo_login@example.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# ── Document Storage: Cloudinary ────
# 1. Sign up → https://cloudinary.com
# 2. Dashboard → copy cloud_name, api_key, api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Local File Storage (fallback when Cloudinary not set) ────
UPLOAD_DIR=/app/uploads  # inside Docker container

# ── Deployment Hooks (set in GitHub Secrets) ─────────────────
# RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxx?key=yyy
# (Not used in .env — add as GitHub Actions secret)
